# ---------------------------------------------------------------------------
# Environment variables — copy this file to `.env` and fill in the values.
# NEVER commit `.env` to version control.
# ---------------------------------------------------------------------------

# --- Postgres (Airflow metadata DB) ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# --- Airflow ---
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=your_airflow_secret_key

# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your_airflow_core_fernet_key

# Airflow admin user created on first `airflow-init` run
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Maps the Airflow container user to the host user ID to prevent permission errors on mounted volumes.
AIRFLOW_UID=1000

# --- GCP ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-east1
GCS_BUCKET=your-gcs-bucket-name

# --- Kaggle ---
# Found at https://www.kaggle.com/settings → API → API Tokens → Generate New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# --- BigQuery datasets ---
BQ_RAW_DATASET=eu_football_raw
BQ_STAGING_DATASET=eu_football_staging
BQ_MART_DATASET=eu_football_mart
